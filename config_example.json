{
  "version": "9.1.6",
  "tier": "beta",

  "paths": {
    "input_file": "/percorso/al/tuo/dataset.jsonl",
    "output_dir": "/percorso/output"
  },

  "processing": {
    "split_size": 5000,
    "batch_size": 20,
    "max_parallel_workers": 2,
    "worker_timeout_seconds": 120,
    "recheck_interval_seconds": 30
  },

  "ai": {
    "provider": "anthropic",
    "fallback_provider": null,
    "model": "claude-haiku-4-5-20251001",
    "temperature": 0.0,
    "max_tokens": 2048,
    "max_retries": 3,
    "retry_delay_base": 2.0,
    "system_prompt": "Correggi solo gli errori meccanici nel testo: apostrofi mancanti, maiuscole errate a inizio frase e refusi ortografici evidenti. Non riformulare, non parafrasare, non migliorare lo stile o la fluidità. Se il testo è già corretto, restituiscilo invariato. Restituisci solo il testo corretto, senza spiegazioni.",
    "api_keys": {
      "anthropic": "INSERISCI_LA_TUA_API_KEY_QUI"
    }
  },

  "storage": {
    "backend": "filesystem",
    "use_file_locking": true
  },

  "logging": {
    "level": "INFO",
    "rotation": "10 MB",
    "retention": "30 days",
    "enable_json_logs": false
  },

  "license": {
    "license_file": null,
    "validation_url": null,
    "allow_offline_mode": true,
    "offline_grace_period_days": 7
  }
}
